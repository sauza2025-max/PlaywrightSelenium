<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Playwright + Selenium Learning Suite" verbose="2" parallel="classes" thread-count="2">

    <listeners>
        <!-- Add a listener here if you want custom TestNG reporting hooks -->
    </listeners>

    <!-- ==================== SELENIUM TESTS ==================== -->
    <test name="Selenium Tests">
        <classes>
            <class name="tests.selenium.SeleniumExampleTests"/>
        </classes>
    </test>

    <!-- ==================== PLAYWRIGHT TESTS ==================== -->
    <test name="Playwright Tests">
        <classes>
            <class name="tests.playwright.PlaywrightExampleTests"/>
        </classes>
    </test>

</suite>
